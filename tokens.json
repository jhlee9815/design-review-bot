      "info": {
        "default": { "$value": "{primitives.blue.500}",      "$type": "color" },
        "bg":      { "$value": "{primitives.blue.50}",       "$type": "color" },
        "text":    { "$value": "{primitives.blue.700}",      "$type": "color" },
        "border":  { "$value": "{primitives.blue.300}",      "$type": "color" }
