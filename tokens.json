      "focus":     { "$value": "{primitives.neutral.100}",   "$type": "color" }
    },
    "icon": {
      "primary":   { "$value": "{primitives.neutral.100}",   "$type": "color" },
      "secondary": { "$value": "{primitives.neutral.500}",   "$type": "color" },
