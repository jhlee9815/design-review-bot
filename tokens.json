      "inverse":   { "$value": "{primitives.base.white}",    "$type": "color" },
      "danger":    { "$value": "{primitives.red.700}",       "$type": "color" },
      "disabled":  { "$value": "{primitives.neutral.400}",   "$type": "color" }
    },
    "border": {
      "default":   { "$value": "{primitives.neutral.200}",   "$type": "color" },
      "strong":    { "$value": "{primitives.neutral.400}",   "$type": "color" },
      "focus":     { "$value": "{primitives.neutral.900}",   "$type": "color" }
    },
    "icon": {
      "primary":   { "$value": "{primitives.neutral.900}",   "$type": "color" },
      "secondary": { "$value": "{primitives.neutral.400}",   "$type": "color" },
      "inverse":   { "$value": "{primitives.base.white}",    "$type": "color" },
      "disabled":  { "$value": "{primitives.neutral.300}",   "$type": "color" }
    },
    "brand": {
      "primary":   { "$value": "{primitives.neutral.900}",   "$type": "color" },
      "inverse":   { "$value": "{primitives.base.white}",    "$type": "color" },
      "accent":    { "$value": "{primitives.red.600}",       "$type": "color" }
    },
    "interactive": {
      "primary":   { "$value": "{primitives.neutral.900}",   "$type": "color" },
      "hover":     { "$value": "{primitives.neutral.800}",   "$type": "color" },
      "pressed":   { "$value": "{primitives.neutral.700}",   "$type": "color" },
      "disabled":  { "$value": "{primitives.neutral.200}",   "$type": "color" }
    },
    "status": {
      "success": {
        "default": { "$value": "{primitives.green.500}",     "$type": "color" },
        "bg":      { "$value": "{primitives.green.50}",      "$type": "color" },
        "text":    { "$value": "{primitives.green.700}",     "$type": "color" },
        "border":  { "$value": "{primitives.green.300}",     "$type": "color" }
      },
      "warning": {
        "default": { "$value": "{primitives.yellow.500}",    "$type": "color" },
        "bg":      { "$value": "{primitives.yellow.50}",     "$type": "color" },
        "text":    { "$value": "{primitives.yellow.700}",    "$type": "color" },
        "border":  { "$value": "{primitives.yellow.300}",    "$type": "color" }
