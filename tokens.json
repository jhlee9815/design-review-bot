      "error": {
        "default": { "$value": "{primitives.red.600}",       "$type": "color" },
        "bg":      { "$value": "{primitives.red.50}",        "$type": "color" },
        "text":    { "$value": "{primitives.red.700}",       "$type": "color" },
        "border":  { "$value": "{primitives.red.300}",       "$type": "color" }
      },
      "danger": {
        "default": { "$value": "{primitives.red.700}",       "$type": "color" },
        "bg":      { "$value": "{primitives.red.50}",        "$type": "color" },
        "text":    { "$value": "{primitives.red.700}",       "$type": "color" }
      }
    },
    "danger": {
      "default":   { "$value": "{primitives.red.700}",       "$type": "color" },
      "bg":        { "$value": "{primitives.red.50}",        "$type": "color" }
    }
  },

  "semantic-dark": {
