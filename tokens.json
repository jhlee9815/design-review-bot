    "12": { "$value": "12px", "$type": "spacing" },
    "16": { "$value": "16px", "$type": "spacing" },
    "20": { "$value": "20px", "$type": "spacing" },
    "24": { "$value": "24px", "$type": "spacing" },
    "32": { "$value": "32px", "$type": "spacing" },
    "40": { "$value": "40px", "$type": "spacing" },
    "48": { "$value": "48px", "$type": "spacing" }
  },

  "radius": {
    "none": { "$value": "0px",    "$type": "borderRadius" },
    "xs":   { "$value": "4px",    "$type": "borderRadius" },
    "sm":   { "$value": "8px",    "$type": "borderRadius" },
    "md":   { "$value": "12px",   "$type": "borderRadius" },
    "lg":   { "$value": "16px",   "$type": "borderRadius" },
    "xl":   { "$value": "20px",   "$type": "borderRadius" },
    "full": { "$value": "9999px", "$type": "borderRadius" }
  },

  "shadow": {
    "card":          { "$value": "0 2px 8px rgba(0,0,0,0.08)",       "$type": "shadow" },
    "modal":         { "$value": "0 8px 24px rgba(0,0,0,0.16)",      "$type": "shadow" },
    "dropdown":      { "$value": "0 4px 16px rgba(0,0,0,0.12)",      "$type": "shadow" },
    "focused":       { "$value": "0 0 0 3px rgba(23,23,23,0.15)",    "$type": "shadow" },
    "error-focused": { "$value": "0 0 0 3px rgba(220,38,38,0.2)",    "$type": "shadow" }
  },

  "component": {
    "button": {
      "height-lg":     { "$value": "52px",           "$type": "sizing" },
      "height-md":     { "$value": "40px",           "$type": "sizing" },
      "max-width":     { "$value": "335px",          "$type": "sizing" },
      "border-radius": { "$value": "{radius.full}",  "$type": "borderRadius" },
      "border-width":  { "$value": "1.5px",          "$type": "borderWidth" }
    },
    "input": {
      "width":         { "$value": "350px",          "$type": "sizing" },
      "height":        { "$value": "48px",           "$type": "sizing" },
      "border-radius": { "$value": "{radius.sm}",    "$type": "borderRadius" },
      "padding-x":     { "$value": "{spacing.16}",   "$type": "spacing" },
      "border-width": {
        "default":       { "$value": "1px",          "$type": "borderWidth" },
        "focused":       { "$value": "2px",          "$type": "borderWidth" },
        "error":         { "$value": "1px",          "$type": "borderWidth" },
        "error-focused": { "$value": "2px",          "$type": "borderWidth" }
      }
    },
    "otp-cell": {
      "width":         { "$value": "50px",           "$type": "sizing" },
      "height":        { "$value": "56px",           "$type": "sizing" },
      "border-radius": { "$value": "{radius.md}",    "$type": "borderRadius" },
      "border-width": {
        "empty":         { "$value": "1px",          "$type": "borderWidth" },
        "focused":       { "$value": "1.4px",        "$type": "borderWidth" },
        "filled":        { "$value": "1.4px",        "$type": "borderWidth" },
        "error":         { "$value": "1.4px",        "$type": "borderWidth" },
        "error-focused": { "$value": "2px",          "$type": "borderWidth" }
