      "disabled":  { "$value": "{primitives.neutral.200}",   "$type": "color" },
      "overlay":   { "$value": "rgba(23, 23, 23, 0.6)",      "$type": "color" },
      "invert":    { "$value": "{primitives.neutral.900}",   "$type": "color" }
