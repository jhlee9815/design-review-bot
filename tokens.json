      "size-md":       { "$value": "40px",           "$type": "sizing" },
      "size-sm":       { "$value": "32px",           "$type": "sizing" },
      "border-radius": { "$value": "{radius.full}",  "$type": "borderRadius" }
    },
    "modal": {
