      "icon-bg-radius":{ "$value": "{radius.md}",    "$type": "borderRadius" }
    },
    "tab-nav": {
      "height":           { "$value": "44px", "$type": "sizing" },
      "indicator-height": { "$value": "2px",  "$type": "sizing" }
    },
    "screen": {
      "padding-x": { "$value": "{spacing.20}", "$type": "spacing" },
      "width":     { "$value": "390px",        "$type": "sizing" }
